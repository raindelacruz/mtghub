MTGHUB_ENV=development
MTGHUB_APP_NAME="MTGHub PH"
MTGHUB_BASE_URL=/mtghub/public
MTGHUB_ASSET_URL=/mtghub/assets
MTGHUB_DB_HOST=127.0.0.1
MTGHUB_DB_NAME=mtghub
MTGHUB_DB_USER=mtghub_app
MTGHUB_DB_PASSWORD=change-this-password
MTGHUB_DB_CHARSET=utf8mb4
MTGHUB_PASSWORD_RESET_TTL=3600
MTGHUB_PUBLIC_ORIGIN=http://localhost
MTGHUB_SMTP_HOST=smtp.gmail.com
MTGHUB_SMTP_PORT=587
MTGHUB_SMTP_ENCRYPTION=tls
MTGHUB_SMTP_USERNAME=your-email@gmail.com
MTGHUB_SMTP_PASSWORD=your-google-app-password
MTGHUB_MAIL_FROM_EMAIL=your-email@gmail.com
MTGHUB_MAIL_FROM_NAME="MTGHub PH"
MTGHUB_SMTP_TIMEOUT=15
